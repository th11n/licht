{
  "name": "core",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.mjs",
  "bin": {
    "licht": "./bin/licht.js"
  },
  "scripts": {
    "build": "tsdown src/cli/index.ts --out-dir dist",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/cli/index.ts --outfile licht",
    "dev": "cd .",
    "dev:init": "bun run src/cli/index.ts init",
    "dev:start": "bun run src/cli/index.ts start",
    "start": "bun run dist/index.mjs start"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "catalog:",
    "env-paths": "^4.0.0",
    "hono": "^4.8.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@licht/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}